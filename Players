@Composable
fun UpdateUIExampble(modifier: Modifier = Modifier) {

    val players = remember { mutableSetOf("Ahmed", "Khalid", "Hassan", "Renad") }
    var selectedIndex by remember { mutableIntStateOf(0) }


    Column(modifier = modifier.fillMaxSize(), verticalArrangement = Arrangement.Center) {
        Text(
            text = "The palyer is: ${players.elementAt(selectedIndex)}",
            fontSize = 35.sp,
            lineHeight = 70.sp,
            textAlign = TextAlign.Center,
            color = Color.Blue
        )

        Button(
            onClick = {
                if (selectedIndex == players.indices.last) {
                    selectedIndex = players.indices.first
                } else {
                    selectedIndex += 1
                }

            },
            content = {
                Text(
                    text = "Next palyer",
                    fontSize = 23.sp,
                    lineHeight = 20.sp,
                    color = Color.Yellow

                )

            }
        )

    }
}

@Preview(
    showBackground = true,
    showSystemUi = true
)
@Composable
fun PreviewUpdateUIExampble() {
    UpdateUIExampble(
        Modifier.fillMaxSize()
    )

}